# ── Server ──────────────────────────────────────────────
PORT=3000

# ── Telnyx ──────────────────────────────────────────────
TELNYX_KEY=KEY...                 # Telnyx API v2 key
TELNYX_CONNECTION_ID=             # Voice API Application connection_id (set after app is created)
TELNYX_PUBLIC_KEY=                # Telnyx webhook signing public key (for signature verification)

# ── Webhook auth ────────────────────────────────────────
WH_TOKEN=trinity-2026             # shared-secret query token on the webhook URL

# ── Supabase ────────────────────────────────────────────
SUPABASE_HOST=xxxx.supabase.co
SUPABASE_KEY=                     # service_role key (server-side only)

# ── Dialer defaults ─────────────────────────────────────
AMD_MODE=premium                  # premium | detect | disabled
